{
  "name": "@vcds/vue",
  "version": "0.0.1",
  "description": "Vue 3 component library — thin wrappers over @vcds/css-components",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": ["dist", "src"],
  "scripts": {
    "build": "vue-tsc --noEmit && vite build",
    "dev": "vite build --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@vcds/css-components": "workspace:*",
    "@vcds/shared": "workspace:*",
    "@vcds/tokens": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
